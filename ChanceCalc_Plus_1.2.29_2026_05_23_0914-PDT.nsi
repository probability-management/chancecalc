;;WriteRegDWORD HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\SIPmath Modeler Tools" "NoModify" 1
;;WriteRegDWORD HKLM "Software\Microsoft\Windows\CurrentVersion\Uninstall\SIPmath Modeler Tools" "NoRepair" 1

SectionEnd

