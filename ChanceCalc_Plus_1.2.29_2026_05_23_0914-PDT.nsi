;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;
; Automatically install add-in to Excel
;
;;SetRegView 64
; Check Installed Excel Version
ReadRegStr $1 HKCR "Excel.Application\CurVer" ""

; ${If} $1 == 'Excel.Application.8' ; Excel 95
; StrCpy $2 "8.0"
; ${ElseIf} $1 == 'Excel.Application.9' ; Excel 2000
; StrCpy $2 "9.0"
; ${ElseIf} $1 == 'Excel.Application.10' ; Excel XP
; StrCpy $2 "10.0"
; ${ElseIf} $1 == 'Excel.Application.11' ; Excel 2003
; StrCpy $2 "11.0"
; ${ElseIf} $1 == 'Excel.Application.12' ; Excel 2007?
; StrCpy $2 "12.0"
; ${ElseIf} $1 == 'Excel.Application.13' ; Does this exist?
; StrCpy $2 "13.0"
; ${ElseIf} $1 == 'Excel.Application.14' ; Excel 2010
${If} $1 == 'Excel.Application.14'; 
StrCpy $2 "14.0"
${ElseIf} $1 == 'Excel.Application.15' ; Mac version?
StrCpy $2 "15.0"
${ElseIf} $1 == 'Excel.Application.16' ;
StrCpy $2 "16.0"
${Else}
MessageBox MB_OK "Setup can't automatically activate the add-in. You must manually activate the add-in after installation."
StrCpy $2 "unknown"
; Abort "An appropriate version of Excel is not installed.$\nNSIS Test setup will be canceled."
${EndIf}

${if} $2 != "unknown"
; dge: see if any files named "ChanceCalc_Plus*.xlam" are listed in the registry under
;  HKCU\Software\Microsoft\Office\$2\Excel\Options\OPEN<n>
; remove any that are found

StrCpy $R0 0
loopRegVals:
  ClearErrors
  EnumRegValue $R1 HKCU "Software\Microsoft\Office\$2\Excel\Options" $R0 
  IfErrors doneRegVals
  StrCpy $R4 $R1 4 ; see if 1st 4 letters of this key name are "OPEN"
  StrCmp $R4 "OPEN" openKey notSmAddin
openKey:
  ; try to get the file name for this key by extracting the last "word" delimited by a backslash
  ReadRegStr $R5 HKCU "Software\Microsoft\Office\$2\Excel\Options" $R1
  ${WordFind} $R5 "\" "-1" $R6 ; this should put the last word in $R6
  ; see if the 'word' begins with ChanceCalc 
  StrCpy $R2 $R6 20 ; copy first 15 letters of $R6 to $R2 ("ChanceCalc_Plus" has 15 letters)
  StrCmp $R2 "ChanceCalc_Plus" beginsWithCC notCCAddin
beginsWithCC:
  StrCpy $R2 $R6 5 -6 ; last 5 letters (except close quote) of the 'word' should be ".xlam"; 
  StrCmp $R2 ".xlam" endsWithXlam notSmAddin
endsWithXlam:
  ; 'word' is apparently , hopefully, a ChanceCalc add-in, so remove it from the registry
  ; so it won't be added in to Excel
  ClearErrors
  DeleteRegValue HKCU "Software\Microsoft\Office\$2\Excel\Options" $R1 ; "OPEN$3"
  ; note that since we deleted this key the current $R0th key is now the next key, so we don't need to increment $R0
  ; and can jump directly back to the top of the loop without incrementing
  ; on the other hand, if the deletion failed for some reason we *should* increment $R0 to avoid an infinite loop
  ; and therefore jump to the increment step
  IfErrors notSmAddin loopRegVals
notCCAddin:
  ; see if the file name for the key is SIpmath<something>.xlam
  StrCpy $R2 $R6 7 ; get 1st 7 letters of file name; 7 = length of the string "SIPmath"
  StrCmp $R2 "SIPmath" beginsWithSm notSmAddin
beginsWithSm:
  StrCpy $R2 $R6 5 -6 ; get 1st 5 of the last 6 letters
  StrCmp $R2 ".xlam" isSipmathXlam notSmAddin
isSipmathXlam:
  ClearErrors
  DeleteRegValue HKCU "Software\Microsoft\Office\$2\Excel\Options" $R1 ; "OPEN$3"
  ; ideally I could now re-use this "OPEN" key I've just deleted but there might
  ; be more "OPEN" keys for other ChanceCalc addins that still need to be deleted,
  ; so I will continue looping
  ; note that since we deleted this key the current $R0th key is now the next key, so we don't need to increment $R0
  ; on the other hand, if the deletion failed for some reason we *should* increment $R0 to avoid an infinite loop
  IfErrors notSmAddin loopRegVals
notSmAddin:
  IntOp $R0 $R0 + 1
  Goto loopRegVals
doneRegVals:
; end dge add

; Find available "OPEN" key
StrCpy $3 ""
loop:
ReadRegStr $4 HKCU "Software\Microsoft\Office\$2\Excel\Options" "OPEN$3"
${If} $4 == ""
; Available OPEN key found
${Else}
IntOp $3 $3 + 1
Goto loop
${EndIf}

; Write install data to registry
WriteRegStr HKCU "Software\ChanceCalc_Plus" "InstallDir" $INSTDIR
; Install Directory
WriteRegStr HKCU "Software\ChanceCalc_Plus" "ExcelCurVer" $2
; Current Excel Version

; Write key to install AddIn in Excel Addin Manager
WriteRegStr HKCU "Software\Microsoft\Office\$2\Excel\Options" "OPEN$3" '"$INSTDIR\ChanceCalc_Plus.xlam"'
${EndIf} ; $2 != "unknown"

;; Write keys to uninstall
